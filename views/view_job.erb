<div class="justify-content-center flex-1">
  <h1 class="my-3 border-bottom py-3 font-weight-bold">Job: <%= @params[:id] %></h1>
</div>

<div class="py-2 justify-content-center">
  <h2 class="font-weight-bold">
    <i class="fas fa-cogs"></i>
    Logs
  </h2>
</div>

<div class="justify-content-center bg-dark overflow-auto p-3 bottom-0 m-3" style="max-height: 500px; max-width: auto;">
  <% File.foreach("#{log_root}/#{params[:id]}.out") do |line| %>
    <p class="text-white text-monospace"><%= line %></p>
  <% end %>
</div>

<div class="py-2 justify-content-center">
  <h2 class="font-weight-bold">
    <i class="fas fa-cogs"></i>
    Manage Job
  </h2>
</div>

<div class="justify-content-center align-content-center" style="width: 100;">
  <form action="<%= url("jobs/#{@params[:id]}") %>" method="post">

    <div class="form-group">
      <input type="hidden" class="form-control" name="job_id" id="job_id" value="<%= params[:id] %>" required>
    </div>

    <div class="d-flex flex-row align-items-center">
      <p class="mr-auto d-flex">Cancel this job across all clusters</p>
      <button type="submit" class="btn btn-primary my-3 ml-auto">Cancel</button>
    </div>
  </form>
</div>