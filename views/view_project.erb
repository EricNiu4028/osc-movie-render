<div class="justify-content-center flex-1">
  <h1 class="my-3 border-bottom py-3 font-weight-bold">Project: <%= @params[:name].gsub('_', ' ').split.map(&:capitalize).join(' ') %></h1>
</div>

<% unless videos(params[:name]).empty? %>
  <video class="w-100" autoplay muted loop playsinline controls src="/pun/sys/dashboard/files/fs<%= videos(params[:name]).first %>"></video>
<% end %>

<div class="py-2 justify-content-center">
<h2 class="font-weight-bold">
<i class="fas fa-film fa-fw"></i>
Render Frames</h2>
</div>

<div class="justify-content-center" id="renderFrames">
  <form action="<%= url("render/frames") %>" method="post">
  
    <div class="col-md-12">
    <div class="row">

      <div class="form-group col-md-4">
        <label for="blend_file">Blend File</label>
        <select name="blend_file" id="blend_file" class="form-control">
          <%- blend_files(@params[:name]).each do |file| -%>
            <option value="<%= file %>"><%= file %></option>
          <%- end -%>
        </select>
      </div>

      <div class="form-group col-md-4">
        <label for="account">Account</label>
        <select name="account" id="account" class="form-control">
          <% accounts.each do |acc| %>
            <option value=<%= acc %>><%= acc %></option>
          <% end %>
        </select>
      </div>

      <div class="form-group col-md-3">
        <label for="nodes">Nodes</label>
        <input id="nodes" name="nodes" type="number" min="1" max="10" class="form-control" value='1' required>
        <small class="form-text text-muted">Split the job across multiple nodes</small>
      </div>

      <div class="form-group col-md-3">
        <label for="num_cpus">CPUs</label>
        <input id="num_cpus" name="num_cpus" type="number" min="4" max="96" class="form-control" value='4' required>
        <small class="form-text text-muted">More CPUs means less time rendering.</small>
      </div>

      <div class="form-group col-md-3">
        <label for="frame_range">Tasks</label>
        <input id="num_tasks" name="num_tasks" type="number" min="1" max="10" class="form-control" value='1' required>
        <small class="form-text text-muted">Runs simultaneous tasks which run jobs faster</small>
      </div>

      <div class="form-group col-md-3">
        <label for="frame_range">Frame Range (N-M)</label>
        <input id="frame_range" name="frame_range" type="text" class="form-control" pattern="(\d+\.\.\d+)|(\d+(?:,\d+)*)" value='1..20' required>
        <small class="form-text text-muted">Ex: "1..10" renders frames 1-10, "1,3,5" renders frames 1, 3 and 5...</small>
      </div>

      <div class="form-group col-md-3">
        <label for="walltime">Walltime</label>
        <input type="number" id="walltime" name="walltime" class="form-control" value="1" min="1" max="48">
        <small class="form-text text-muted">Hours</small>
      </div>

      <div>
        <input type="hidden" name="project_directory" id="project_directory" value="<%= "#{project_root}/#{@params[:name]}" %>" required>
        <input type="hidden" name="project_name" id="project_name" value="<%= @params[:name] %>" required>
      </div>

    </div>

    <div class="row justify-content-md-end my-1">
      <button type="submit" class="btn btn-primary float-right">Render Frames</button>
    </div>
  </form>
</div>

<div class="py-2 justify-content-center">
<h2 class="font-weight-bold">
<i class="fas fa-film fa-fw"></i>
Compile Video</h2>
</div>

<div class="justify-content-center">
  <form action="<%= url("render/video") %>" method="post">
  
    <div class="col-md-12">
    <div class="row">

      <div class="form-group col-md-6">
        <label for="fps">FPS</label>
        <input id="fps" name="fps" type="number" min="1" max="60" class="form-control" value='30' required>
        <small class="form-text text-muted">Increase/Decrease the speed of the video</small>
      </div>

      <div class="form-group col-md-6">
        <label for="account">Account</label>
        <select name="account" id="account" class="form-control">
          <% accounts.each do |acc| %>
            <option value=<%= acc %>><%= acc %></option>
          <% end %>
        </select>
      </div>

      <div class="form-group col-md-4">
        <label for="num_cpus">CPUs</label>
        <input id="num_cpus" name="num_cpus" type="number" min="4" max="96" class="form-control" value='4' required>
        <small class="form-text text-muted">More CPUs generally means faster speeds</small>
      </div>

      <div class="form-group col-md-4">
        <label for="frame_range">Tasks</label>
        <input id="num_tasks" name="num_tasks" type="number" min="1" max="10" class="form-control" value='1' required>
        <small class="form-text text-muted">Runs simultaneous tasks which run jobs faster</small>
      </div>

      <div class="form-group col-md-4">
        <label for="walltime">Walltime</label>
        <input type="number" id="walltime" name="walltime" class="form-control" value="1" min="1" max="48">
        <small class="form-text text-muted">Hours</small>
      </div>

      <div>
        <input type="hidden" name="project_directory" id="project_directory" value="<%= "#{project_root}/#{@params[:name]}" %>" required>
        <input type="hidden" name="project_name" id="project_name" value="<%= @params[:name] %>" required>
      </div>

    </div>

    <div class="row justify-content-md-end my-1">
      <button type="submit" class="btn btn-primary float-right">Render Frames</button>
    </div>
  </form>
</div>

<div class="job-section mt-5">
  <div class="d-flex">
    <h2 class="display-7 py-3 font-weight-bold">
      Project Files:
    </h2>
    <div class="justify-content-center align-content-center ml-auto">
      <form action="<%= url("upload/file") %>" method="post" enctype="multipart/form-data" class="d-flex">

        <div class="form-group d-flex align-items-center">
          <input type="hidden" class="form-control" name="project_name" id="project_name" value="<%= params[:name] %>" required>
          <input class="form-control m-3" type="file" id="upload_file" name="upload_file">
          <button type="submit" class="btn btn-primary my-3">Upload</button>
        </div>
      </form>
    </div>
  </div>
  <table class="table">
    <thead>
      <tr>
        <th scope="col">Name</th>
        <th class="d-flex justify-content-center" scope="col">Type</th>
        <th scope="col">Location</th>
        <th scope="col">Modified</th>
        <th scope="col">Account</th>
      </tr>
    </thead>
    <tbody>
      <% project_files(params[:name]).each do |file| %>
        <tr>
          <th scope="row"><%= file[:name] %></th>
          <td class="d-flex justify-content-center"><i class="fas <%= file[:file] ? 'fa-file' : 'fa-folder' %>"></i></td>
          <td><%= file[:full_path] %></td>
          <td><%= file[:mt_time] %></td>
          <td><%= file[:account] %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
    
</div>

<div class="py-2 justify-content-center">
  <h2 class="font-weight-bold">
    <i class="fas fa-cogs"></i>
    Manage Project
  </h2>
</div>

<div class="justify-content-center align-content-center">
  <form action="<%= url("projects/#{@params[:name]}") %>" method="post">

    <div class="form-group">
      <input type="hidden" class="form-control" name="delete" id="delete" value="<%= params[:name] %>" required>
    </div>

    <button type="submit" class="btn btn-primary my-3">Delete</button>
  </form>
</div>